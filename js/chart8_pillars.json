{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "International Tourism Demand Pillars",
    "subtitle": "Absolute visitor arrivals by top global source markets (Jan-Apr 2025)",
    "anchor": "start",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "subtitleColor": "#586069",
    "offset": 15
  },
  "width": 350,
  "height": 330,
  "padding": {"left": 10, "right": 20, "top": 10, "bottom": 10},
  "data": {
    "values": [
      {"Country": "Singapore", "Arrivals": 6526262},
      {"Country": "Indonesia", "Arrivals": 1466923},
      {"Country": "China", "Arrivals": 1441184},
      {"Country": "Thailand", "Arrivals": 833610},
      {"Country": "India", "Arrivals": 484791}
    ]
  },
  "config": {
    "background": "#ffffff",
    "view": {"stroke": "transparent"},
    "axis": {"grid": false}
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4
  },
  "encoding": {
    "y": {
      "field": "Country",
      "type": "nominal",
      "title": null,
      "sort": "-x",
      "axis": {
        "labelFontSize": 11,
        "domain": true,
        "ticks": false,
        "labelPadding": 10
      }
    },
    "x": {
      "field": "Arrivals",
      "type": "quantitative",
      "title": "Absolute Visitor Headcount",
      "axis": {
        "domain": true,
        "ticks": true,
        "labelFontSize": 10,
        "titlePadding": 12,
        "format": ",.0f"
      }
    },
    "color": {
      "field": "Arrivals",
      "type": "quantitative",
      "scale": {"scheme": "oranges"},
      "legend": null
    },
    "tooltip": [
      {"field": "Country", "type": "nominal", "title": "Source Country"},
      {"field": "Arrivals", "type": "quantitative", "title": "Arrivals (Jan-Apr 2025)", "format": ",d"}
    ]
  }
}